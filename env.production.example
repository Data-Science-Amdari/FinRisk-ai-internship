# FinRisk Production Environment Configuration
# Copy this file to .env and update with your production values

# Application Settings
APP_NAME=FinRisk
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://finrisk_user:your_secure_password@your_db_host:5432/finrisk_db

# Redis Configuration
REDIS_URL=redis://your_redis_host:6379/0

# MLflow Configuration
MLFLOW_TRACKING_URI=http://your_mlflow_host:5000

# Security Settings
SECRET_KEY=your_super_secure_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Paths
CREDIT_MODEL_PATH=models/credit_risk_model.pkl
FRAUD_MODEL_PATH=models/fraud_detection_model.pkl

# Data Paths
DATA_DIRECTORY=data

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# CORS Settings
CORS_ORIGINS=["https://your-frontend-domain.com", "https://api.your-domain.com"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Cache Settings
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# Logging
LOG_FORMAT=json
LOG_FILE_PATH=logs/finrisk.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5
